# PitchPoint — copy this file to `.env` (already gitignored) and fill values.

# Google Maps APIs (Geocoding, Static Maps, Solar, Address Validation, Street View Static)
GOOGLE_MAPS_API_KEY=

# OpenAI vision (synthesizer LLM + multi-shot pitch). Multiple keys supported for round-robin.
OPENAI_API_KEY=
OPENAI_API_KEY2=
OPENAI_API_KEY3=
OPENAI_API_KEY4=
OPENAI_VISION_MODEL=gpt-5.5

# Gemini Pro 3.1 vision (alternate multi-shot path; also synthesizer fallback)
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-3.1-pro-preview

# Frontend (Vite). Same Google Maps API key — the Places autocomplete uses it.
VITE_GOOGLE_MAPS_API_KEY=

# Pipeline defaults
DEFAULT_ZOOM=20
DEFAULT_SCALE=2
DEFAULT_IMAGE_SIZE=640x640
DEFAULT_BUFFER_METERS=150
